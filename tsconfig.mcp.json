{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "node",
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "noEmit": false
    },
    "include": [
        "src/mcp-server.ts",
        "src/services/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}